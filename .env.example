# Required on the server for Gemini API calls.
# Keep this secret. Do not expose it as a VITE_* variable.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# Optional build-time setting for large static files.
# Leave empty to serve files from this repository's public/ folder.
# Set to a CDN or Cloud Storage public base URL later, for example:
# VITE_ASSET_BASE_URL="https://storage.googleapis.com/YOUR_BUCKET"
VITE_ASSET_BASE_URL=""
